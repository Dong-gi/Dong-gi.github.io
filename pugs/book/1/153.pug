include ../../../source/skeleton.pug

+post({
    title: '딜레마',
    description: '개인적으로 마음에 든 『딜레마』 문구',
})

    h1 도서 정보
    +bookInfo({
        imgSrc: 'https://contents.kyobobook.co.kr/sih/fit-in/458x0/pdt/9791130600789.jpg',
        title: '딜레마',
        author: '뤼방 오지앙',
        publisher: '(주식회사)다산북스',
        isbn: '979-11-306-0078-9 (03190)',
        date: '2013.11.22',
    })

    h1 독서 기록
    ul 
        li 사람을 죽이는 것과, 죽게 내버려두는 것은 결과가 같으니 같은 행동일까?
            ul
                li 의도가 중요하다면: 유산을 상속받기 위해 직접 죽이는 것과, 유산을 상속받기 위해 죽어가는 부모를 방치하는 것은 같은 행동일까?
                li 혹시 대상이 극악무도한 사람이라면 어느 쪽이든 정당화될까?
                li 컴퓨터 마우스를 클릭하는 것만으로 어린아이의 생명을 구할 수 있다면, 마우스를 클릭하지 않는 것과 어린아이를 죽게 내버려두는 것 사이에 차이가 있을까?
                li 칸트는 어떤 예외도 용납될 수 없는 도덕적 의무를 주장한다. 살인자들이 집 앞에 찾아와 자기들이 쫓는 사람이 집 안에 있느냐고 물어도 거짓말을 해서는 안 된다
                    ul
                        li 소극적 책임감 배제 : 다른 사람들이 우리를 이용해서 저지른 부도덕한 행위에 책임감을 느낄 필요가 없다
                        li 소극적 책임감 용인 : 우리가 기아를 직접 유발하지 않았다고, 상황을 변화시키기 위해 행동에 나서지 않는 것은 잘못이다 -- 책임감을 느껴야 한다

        li 다수를 구하기 위해 1명을 죽이는 것은 괜찮을까?
            ul
                li 응답자 89%가 전차의 진로를 변경해 1명을 죽이는 것은 괜찮다고 응답한 반면, 전차를 멈출 정도로 뚱뚱한 1명을 밀어뜨려 전차를 멈추는 것은 11%만이 괜찮다고 했다
                li 이중 효과의 독트린 : 행위자가 선한 목표로 행한 것이라면, 사이드 이펙트로 악한 결과가 있더라도 그 행위는 도덕적으로 허용된다고 주장
                    p 따라서 사람을 밀어뜨려 열차를 멈추는 것과, 어쩔 수 없는 부수 효과로 죽는 것은 도덕적으로 다른 행위다

        li 다른 누구도 피해를 입지 않은 행위 -- 오히려 행위 당사자들은 좋아한 행위도 부도덕적일 수 있을까?
            ul
                li 예. 성인간 합의에 따른 근친상간 -- 가능한 모든 피임수칙을 철저히 지키고, 행위를 둘 만의 비밀로 했다
                li 예. 신성모독과 같은, 추상적 본질에 대한 침해
                li 1993년 출판된 헤이트의 첫 연구들의 결론은 엄밀히 말해 도덕주의에 '자연적'이거나 '보편적'인 경향은 전혀 존재하지 않는다는 것이다

        li 왜 도덕적이어야 하는가?
            ul
                li 무도덕자에게 '그런 행동은 나쁘니까 하면 안 돼' 따위의 의무론적 이유를 내세우는 것은 터무니없다
                li '모든 사람이 똑같이 행동한다면 어떨까?'라는 질문은 무익하다 -- 이 논쟁은 다른 사람의 우산을 집어가는 사람에게 당신은 도덕 체계의 '기생충'임을 이해시키려는 듯하다
                li '당신의 행위를 다른 사람이 똑같이 갚아주어도 좋은지?' -- 마조히스트는 다른 사람들을 고문해도 괜찮은가?

        li 도덕적 추론의 기본원칙?
            ul
                li 있는 것에서 있어야 하는 것을 끌어올 수는 없다
                    ul
                        li 사실에 대한 판단에서 의무 혹은 금지 규범으로 이행할 수 없다
                            p 예. "대부분의 사람들이 도둑질하면 안 된다고 믿는다"는 사실로부터 "도둑질하면 안 된다"는 규범을 이끌어낼 수 없다
                        li 존 설은 "짐이 줄에게 '너에게 20유로를 주기로 약속할게'라고 말했다"는 발화에 근거하여 "짐은 줄에게 20유로를 줘야 한다"는 규범적 발화를 논리적으로 끌어낼 수 있다고 주장했다
                            p 그렇다면 "줄은 기회가 닿는 대로 짐의 DVD 모음집을 훔치겠다 약속"한 경우, "줄은 짐의 DVD 모음집을 훔쳐야 한다"는 결론을 끌어낼 수 있는가?
                            p 의무가 생겨나려면 뭔가를 약속하는 것만으로는 충분하지 않다. 만약 서술의 측면과 따로 떼어 생각할 수 없는 규범의 측면을 포함한 약속 개념을 받아들인다면, 우리는 '너에게 20유로를 주기로 약속할게'라는 발화가 더 이상 순전히 서술적이라고 말할 수 없을 것이다
                        li 자연주의자들은 이 규칙이 현대의 발명품이고 우리를 도덕에서 점점 떼어놓는다고 주장한다
                            p 예. 우리는 화초의 자연적인 필요(물을 흡수해야 한다)에서 규범적 결론(물을 줘야 한다)을 끌어낼 수 있다
                        li 공리주의는 바라는 것(우리는 자연적으로 쾌락을 극대화하려고 한다)에서 바람직한 것(쾌락을 극대화해야 한다)을 끌어낸다
                li 의무는 능력을 내포한다
                    ul
                        li 하지만 '능력'이라는 용어는 정의하기 힘들다
                        li 늦잠을 자서 알람을 듣지 못해 약속 시간까지 도착할 수 없게 됐다면, 약속 장소에 가야하는 의무는 무효가 되는 걸까?
                        li 모르는 사이에 누군가가 타둔 수면제를 복용해 늦잠을 자서 알람을 듣지 못해 약속 시간까지 도착할 수 없게 됐다면, 약속 장소에 가야하는 의무는 무효가 되는 걸까?
                li 유사한 사례는 유사한 방식으로 다뤄야 한다
                    ul
                        li 최초 판단이 잘못된다면 연쇄적으로 잘못된 판단을 하게 된다
                        li 다만 이 규칙은 다른 유사한 사례로의 필연적 이행을 지지하는 것은 아니다
                            p 안마사와 성 노동자가 도덕적으로 다를 바 없다고 주장한다고 해서, 안마사가 필연적으로 성을 팔게 된다고 주장하는 것은 아니다

        li 도덕을 '세우려고' 애쓰지 말자?
            ul
                li 최근 수립된 도덕 발전 이론 중 하나는 우리 인간이 어린 나이부터 다음 세 가지 여역을 구별할 수 있다고 주장한다
                    ul
                        li 도덕의 영역
                        li 관습의 영역
                        li 개인적 영역
